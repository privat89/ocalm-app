# ─── OCALM Backend — Variables d'environnement ───────────────────────
# Copie ce fichier : cp env-template .env

# PostgreSQL
DATABASE_URL=postgresql://ocalm_user:ocalm_secret_2025@localhost:5432/ocalm

# Redis
REDIS_URL=redis://:ocalm_redis_2025@localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://ocalm:ocalm_rabbit_2025@localhost:5672

# JWT
JWT_SECRET=ocalm_jwt_secret_dev_only
JWT_EXPIRY=7d

# OTP
OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6

# Wave CI (sandbox)
WAVE_API_KEY=wave_sandbox_key
WAVE_API_SECRET=wave_sandbox_secret
WAVE_WEBHOOK_SECRET=wave_webhook_secret_dev
WAVE_BASE_URL=https://api.wave.com/v1

# MinIO (local S3)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=ocalm_minio
MINIO_SECRET_KEY=ocalm_minio_2025
MINIO_BUCKET=ocalm-evidence

# SMS (sandbox)
SMS_API_KEY=sms_sandbox_key
SMS_SENDER=OCALM

# Firebase (notifications)
FCM_SERVICE_ACCOUNT=./firebase-service-account.json

# Node
NODE_ENV=development
